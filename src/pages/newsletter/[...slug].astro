---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
	const issues = await getCollection('newsletter');
	return issues.map((issue) => ({
		params: { slug: issue.id },
		props: issue,
	}));
}

type Props = CollectionEntry<'newsletter'>;

const issue = Astro.props;
const { Content } = await render(issue);
const { title, description, pubDate, topic, issue: issueNumber } = issue.data;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: #e0e6ed;
			}
			.issue-header {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
			}
			.issue-meta {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
			}
			.issue-badge {
				font-size: 0.8em;
				padding: 0.25em 0.8em;
				background: rgba(0, 240, 255, 0.1);
				border: 1px solid rgba(0, 240, 255, 0.3);
				border-radius: 20px;
				color: #00f0ff;
				font-weight: bold;
			}
			.topic-badge {
				font-size: 0.8em;
				padding: 0.25em 0.8em;
				background: rgba(0, 128, 255, 0.1);
				border: 1px solid rgba(0, 128, 255, 0.3);
				border-radius: 20px;
				color: #60b0ff;
			}
			.issue-header h1 {
				margin: 0 0 0.4em;
				color: #fff;
				line-height: 1.2;
			}
			.date {
				color: #a0aec0;
				font-size: 0.9em;
			}
			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				color: #a0aec0;
				text-decoration: none;
				font-size: 0.9em;
				margin-bottom: 1.5em;
				transition: color 0.2s;
			}
			.back-link:hover {
				color: #00f0ff;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<a href="/newsletter" class="back-link">&#8592; All Newsletters</a>
					<div class="issue-header">
						<div class="issue-meta">
							{issueNumber && <span class="issue-badge">Issue #{issueNumber}</span>}
							{topic && <span class="topic-badge">{topic}</span>}
						</div>
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<hr />
					</div>
					<Content />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
